{
  "name": "unitree-mujoco-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-based Unitree RL policy player — MuJoCo WASM physics + onnxruntime-web inference, FSM, live policy switching, gamepad teleop.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
